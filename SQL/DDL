-- Database: E-Commerce System (PostgreSQL)
-- Generated DDL Script based on UML Class Diagram

-- 1. Create Custom ENUM Types
CREATE TYPE user_role AS ENUM ('BUYER', 'SELLER');
CREATE TYPE product_category AS ENUM ('Children', 'Electricity', 'Office', 'Clothing');

-- 2. Create Users Table (Combines Buyer and Seller logic)
CREATE TABLE Users (
    user_id SERIAL PRIMARY KEY,
    username VARCHAR(100) NOT NULL UNIQUE,
    password VARCHAR(255) NOT NULL,
    role user_role NOT NULL
);

-- 3. Create Addresses Table (1:1 or 1:N relationship with Buyer)
CREATE TABLE Addresses (
    address_id SERIAL PRIMARY KEY,
    user_id INT NOT NULL REFERENCES Users(user_id) ON DELETE CASCADE,
    country VARCHAR(100) NOT NULL,
    city VARCHAR(100) NOT NULL,
    street VARCHAR(150) NOT NULL,
    house_number INT NOT NULL
);

-- 4. Create Products Table
CREATE TABLE Products (
    product_id SERIAL PRIMARY KEY,
    seller_id INT NOT NULL REFERENCES Users(user_id) ON DELETE CASCADE,
    name VARCHAR(255) NOT NULL,
    price NUMERIC(10, 2) NOT NULL CHECK (price >= 0),
    category product_category NOT NULL,
    is_special_prod BOOLEAN DEFAULT FALSE,
    stock INT NOT NULL DEFAULT 0 CHECK (stock >= 0) 
);

-- 5. Create Special Products Table (Subclass of Product)
-- Uses 1:1 relationship with Products table (inherits product_id)
CREATE TABLE Special_Products (
    product_id INT PRIMARY KEY REFERENCES Products(product_id) ON DELETE CASCADE,
    extra_pay NUMERIC(10, 2) NOT NULL CHECK (extra_pay >= 0)
);

-- 6. Create Orders Table (Equivalent to CartHistory)
CREATE TABLE Orders (
    order_id SERIAL PRIMARY KEY,
    buyer_id INT NOT NULL REFERENCES Users(user_id) ON DELETE CASCADE,
    order_time TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- 7. Create Order_Products Table (Many-to-Many relationship between Orders and Products)
CREATE TABLE Order_Products (
    order_id INT NOT NULL REFERENCES Orders(order_id) ON DELETE CASCADE,
    product_id INT NOT NULL REFERENCES Products(product_id) ON DELETE CASCADE,
    quantity INT NOT NULL DEFAULT 1 CHECK (quantity > 0),
    PRIMARY KEY (order_id, product_id)

);
